{
  "name": "sync-indicator",
  "version": "1.0.0",
  "private": true,
  "description": "pnpm workspace root - K线、指标同步服务",
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @sync-indicator/core run build",
    "build:sync": "pnpm --filter @sync-indicator/sync run build",
    "build:api": "pnpm --filter @sync-indicator/api run build",
    "init-db": "pnpm --filter @sync-indicator/sync run init-db",
    "lint": "pnpm -r run lint"
  },
